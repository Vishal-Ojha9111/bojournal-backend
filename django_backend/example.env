# ===================================
# BO JOURNAL - ENVIRONMENT VARIABLES
# ===================================
# Copy this file to .env and fill in your actual values
# Never commit .env file to version control

# -----------------------------------
# DJANGO ENVIRONMENT
# -----------------------------------
# Determines which settings module to load
# Options: development | testing | production
# Default: development
DJANGO_ENVIRONMENT=development

# Legacy flag (kept for backward compatibility, not actively used)
PRODUCTION=False

# -----------------------------------
# DJANGO SECRET KEY
# -----------------------------------
# CRITICAL: Change this to a long random string in production
# Generate with: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=django-insecure-CHANGE-THIS-IN-PRODUCTION

# -----------------------------------
# DATABASE CONFIGURATION
# -----------------------------------
# PostgreSQL connection details
# For development: Use local PostgreSQL
# For production: Use managed database service (RDS, Supabase, etc.)
DB_USER=your_db_username
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bo_journal

# -----------------------------------
# REDIS CONFIGURATION
# -----------------------------------
# Redis is used for caching and Celery message broker
# Format: redis://[username:password@]host:port/db_number
# For development: redis://127.0.0.1:6379/1
# For production: Use managed Redis (ElastiCache, Redis Cloud, etc.)
REDIS_LOCATION=redis://127.0.0.1:6379/1

# -----------------------------------
# EMAIL CONFIGURATION (SMTP)
# -----------------------------------
# SMTP server for sending emails (OTP, welcome, notifications)
# Gmail example (requires app-specific password if 2FA enabled)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password

# For other providers:
# Outlook: smtp.office365.com (port 587)
# SendGrid: smtp.sendgrid.net (port 587)
# AWS SES: email-smtp.region.amazonaws.com (port 587)

# -----------------------------------
# JWT AUTHENTICATION
# -----------------------------------
# Secret key for signing JWT tokens
# CRITICAL: Use a different key than Django SECRET_KEY
# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(64))'
JWT_SECRET=your-jwt-secret-key-change-in-production

# -----------------------------------
# CORS & CSRF CONFIGURATION
# -----------------------------------
# Frontend origins (comma-separated for multiple)
# Development: http://localhost:5173
# Production: https://yourdomain.com
ORIGIN0=https://your-frontend-domain.com
ORIGIN1=http://localhost:5173

# Allowed hosts (comma-separated for multiple)
# Production: your-api-domain.com
HOST0=localhost

# -----------------------------------
# AWS S3 CONFIGURATION
# -----------------------------------
# S3 bucket for storing transaction receipts and profile pictures
# Create IAM user with S3 permissions only (not root account)
S3_REGION=ap-south-1
S3_ACCESS_KEY=your-aws-access-key
S3_SECRET_ACCESS_KEY=your-aws-secret-access-key
S3_BUCKET_NAME=your-bucket-name

# Presigned URL expiration time (seconds)
# Default: 600 seconds (10 minutes)
AWS_PRESIGNED_URL_EXPIRES=600

# -----------------------------------
# TIMEZONE
# -----------------------------------
# Application timezone for date/time operations
# See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=Asia/Kolkata

# -----------------------------------
# PAYMENT GATEWAY (Razorpay)
# -----------------------------------
# Razorpay credentials for subscription payments
# Get from: https://dashboard.razorpay.com/
# Use test keys for development, live keys for production
RAZORPAY_KEY=rzp_test_your_key_here
RAZORPAY_SECRET=your_razorpay_secret_here

# -----------------------------------
# OPTIONAL: ADVANCED SETTINGS
# -----------------------------------

# Custom profile picture URL expiration (seconds)
# If not set, falls back to AWS_PRESIGNED_URL_EXPIRES
# PROFILE_PICTURE_URL_EXPIRES=3600

# Celery broker URL (usually same as REDIS_LOCATION)
# CELERY_BROKER_URL=redis://127.0.0.1:6379/1

# Celery result backend
# CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1

# -----------------------------------
# NOTES
# -----------------------------------
# 1. Development environment reads from this .env file automatically
# 2. Testing environment uses optimized settings (SQLite, no Redis)
# 3. Production environment requires all values to be set properly
# 4. Never expose SECRET_KEY, JWT_SECRET, or database credentials
# 5. Use strong, unique passwords for production
# 6. Enable 2FA on AWS, Razorpay, and email accounts
# 7. Rotate secrets regularly in production
